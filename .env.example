# ── Shopee ──────────────────────────────────────────
# Cadastro em: https://parceiros.shopee.com.br
# Affiliate ID: fixo, identifica sua conta no programa
SHOPEE_AFFILIATE_ID=
# Sub-ID padrão: identifica o canal (ex: grupo_sp_1, bot_flash, painel_manual)
# Pode ser sobrescrito por chamada — útil para rastrear grupos diferentes
SHOPEE_SUB_ID=bot_default

# ── Supabase (lakehouse) ─────────────────────────────
# Crie o projeto em: https://supabase.com/dashboard
# Project Settings → API → Project URL e service_role key
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Banco de dados local (legado, mantido para busca-csv) ─
DB_PATH=data/produtos.db

# ── Landing Page ─────────────────────────────────────
WHATSAPP_GROUP_URL=https://chat.whatsapp.com/LINK_DO_SEU_GRUPO
META_PIXEL_ID=YOUR_PIXEL_ID
GA4_ID=G-XXXXXXXXXX
GTM_ID=GTM-XXXXXXX
